// Svet Povoljnih Cena — Phase 3A schema
// Postgres + Prisma. Money fields use Decimal(12,2) RSD unless stated.
// Covers: auth/account, catalog, promo, stock & supply, delivery,
// orders, service, wishlist & alerts, admin.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearchPostgres", "postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [pg_trgm]
}

// ──────────────────────────────────────────────────────────────────────
// 1. Auth / account (NextAuth + extras)
// ──────────────────────────────────────────────────────────────────────

model User {
  id             String    @id @default(cuid())
  email          String?   @unique
  emailVerified  DateTime?
  phone          String?   @unique
  phoneVerified  DateTime?
  passwordHash   String?
  /// Combined display name (kept in sync with firstName + lastName).
  /// Required by the Auth.js Prisma adapter for OAuth user creation.
  name           String?
  firstName      String?
  lastName       String?
  isBusiness     Boolean   @default(false)
  companyName    String?
  pib            String?
  language       String    @default("sr-Latn")
  image          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?
  lastLoginAt    DateTime?
  /// Incremented when every previously issued JWT must become invalid.
  sessionVersion Int       @default(0)

  accounts           Account[]
  sessions           Session[]
  addresses          Address[]
  savedCards         SavedCard[]
  orders             Order[]
  reclamations       Reclamation[]
  wishlist           WishlistItem[]
  backInStockAlerts  BackInStockAlert[]
  onSaleAlerts       OnSaleAlert[]
  comments           Comment[]
  marketingConsent   MarketingConsent?
  voucherRedemptions VoucherRedemption[]
  cart               Cart?
  checkoutSessions   CheckoutSession[]
  customer           Customer?

  @@index([createdAt])
}

/// Shared, database-backed limiter state. Unlike an in-memory Map this is
/// authoritative across every serverless instance.
model RateLimitBucket {
  key       String   @id @db.VarChar(200)
  count     Int
  resetAt   DateTime
  updatedAt DateTime @updatedAt

  @@index([resetAt])
}

/// Durable outbox for post-commit work. Jobs are claimed with an atomic update
/// and retried by the background-jobs cron until they succeed or exhaust attempts.
model BackgroundJob {
  id             String    @id @default(cuid())
  kind           String    @db.VarChar(80)
  payload        Json
  idempotencyKey String    @unique @db.VarChar(200)
  status         String    @default("QUEUED") @db.VarChar(20)
  attempts       Int       @default(0)
  maxAttempts    Int       @default(8)
  availableAt    DateTime  @default(now())
  lockedAt       DateTime?
  lastError      String?   @db.Text
  completedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([status, availableAt])
  @@index([lockedAt])
}

/// Server-side mirror of the Zustand cart for logged-in users.
/// Stored as JSON to keep the schema flexible while line shapes evolve;
/// rehydrated on login and merged with localStorage cart on the client.
model Cart {
  userId    String   @id
  lines     Json
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// NextAuth standard models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Address {
  id               String   @id @default(cuid())
  userId           String
  label            String?
  firstName        String
  lastName         String
  phone            String
  street           String
  city             String
  postalCode       String
  xExpressTownId   Int?
  xExpressStreetId Int?
  country          String   @default("RS")
  companyName      String?
  pib              String?
  isDefault        Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([city])
}

// Tokenized card reference from the active card acquirer (no PAN stored)
model SavedCard {
  id            String   @id @default(cuid())
  userId        String
  brand         String // visa, master, dina, amex
  last4         String
  expMonth      Int
  expYear       Int
  holderName    String?
  providerToken String   @unique
  isDefault     Boolean  @default(false)
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model MarketingConsent {
  userId    String   @id
  email     Boolean  @default(false)
  sms       Boolean  @default(false)
  viber     Boolean  @default(false)
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum EmailMessageStatus {
  QUEUED
  SENT
  DELIVERED
  OPENED
  CLICKED
  BOUNCED
  COMPLAINED
  FAILED
}

model EmailMessage {
  id                String             @id @default(cuid())
  kind              String
  recipient         String
  subject           String
  provider          String
  providerMessageId String?            @unique
  idempotencyKey    String?            @unique
  status            EmailMessageStatus @default(QUEUED)
  tags              Json?
  metadata          Json?
  error             String?            @db.Text
  createdAt         DateTime           @default(now())
  sentAt            DateTime?
  updatedAt         DateTime           @updatedAt

  events EmailProviderEvent[]

  @@index([kind, createdAt])
  @@index([recipient, createdAt])
  @@index([provider, status])
}

model EmailProviderEvent {
  id                String   @id @default(cuid())
  provider          String
  eventId           String
  type              String
  providerMessageId String?
  messageId         String?
  payload           Json
  receivedAt        DateTime @default(now())

  message EmailMessage? @relation(fields: [messageId], references: [id], onDelete: SetNull)

  @@unique([provider, eventId])
  @@index([providerMessageId])
  @@index([type, receivedAt])
}

model EmailSuppression {
  id              String   @id @default(cuid())
  email           String   @unique
  reason          String
  provider        String?
  providerEventId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([reason, createdAt])
}

// ──────────────────────────────────────────────────────────────────────
// 2. Catalog
// ──────────────────────────────────────────────────────────────────────

model Category {
  id          String     @id @default(cuid())
  slug        String     @unique
  name        String
  parentId    String?
  parent      Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryTree")
  order       Int        @default(0)
  imageUrl    String?
  description String?    @db.Text
  /// Materialized path for fast ancestor queries: "/namestaj/police/otvorene"
  path        String     @unique
  level       Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  products         ProductCategory[]
  deliveryRules    DeliveryPriceRule[]
  linearPromotions LinearPromotionCategory[]
  supplierMappings SupplierCategoryMapping[]

  @@index([parentId, order])
}

model Group {
  id                  String                 @id @default(cuid())
  slug                String                 @unique
  name                String
  products            Product[]
  recommendationRules RecommendationRule[]
  linearPromotions    LinearPromotionGroup[]
}

model Collection {
  id       String    @id @default(cuid())
  slug     String    @unique
  name     String
  products Product[]
}

enum ArticleStatus {
  SP
  IT
  DTZ
  DOB
  ARH
  UZ
}

/// Supplier-owned products are never published until their category mapping
/// and an explicit administrator approval are both present.
enum SupplierProductApprovalStatus {
  PENDING_MAPPING
  PENDING_APPROVAL
  APPROVED
  REJECTED
}

enum SupplierSyncChangeStatus {
  PREVIEW
  PENDING
  APPLIED
  REVERTED
  SKIPPED
  CONFLICT
}

model Product {
  id               String        @id @default(cuid())
  sku              String        @unique
  barcode          String?
  slug             String        @unique
  name             String
  /// The editable final component of the composed storefront name.
  shortName        String?
  description      String        @db.Text
  shortDescription String?       @db.Text
  sizeLabel        String?
  colorPrimary     String?
  colorSecondary   String?
  articleStatus    ArticleStatus @default(SP)

  // ERP article attributes (Atribut 1-4). Boja 1/2 = colorPrimary/colorSecondary.
  attribute1 String?
  attribute2 String?
  attribute3 String?
  attribute4 String?

  groupId      String?
  group        Group?      @relation(fields: [groupId], references: [id])
  collectionId String?
  collection   Collection? @relation(fields: [collectionId], references: [id])

  // Dimensions ŠxDxV (cm)
  widthCm             Decimal?  @db.Decimal(8, 2)
  depthCm             Decimal?  @db.Decimal(8, 2)
  heightCm            Decimal?  @db.Decimal(8, 2)
  weightKg            Decimal?  @db.Decimal(10, 3)
  grossWeightKg       Decimal?  @db.Decimal(10, 3)
  packQty             Int?
  packWidthCm         Decimal?  @db.Decimal(8, 2)
  packDepthCm         Decimal?  @db.Decimal(8, 2)
  packHeightCm        Decimal?  @db.Decimal(8, 2)
  packGrossWeightKg   Decimal?  @db.Decimal(10, 3)
  supplierProductName String?
  materialText        String?   @db.Text
  hsCode              String?
  moq                 Int?
  tncFrom             DateTime?
  tncUntil            DateTime?
  ananasBrokeragePct  Decimal?  @db.Decimal(8, 2)
  ananasStoragePct    Decimal?  @db.Decimal(8, 2)
  ananasDeliveryPct   Decimal?  @db.Decimal(8, 2)

  // Pricing in RSD
  fullPrice          Decimal  @db.Decimal(12, 2)
  salePrice          Decimal? @db.Decimal(12, 2)
  discountPct        Int?
  /// Admin-managed loyalty price for products without an active sale.
  loyaltyPrice       Decimal? @db.Decimal(12, 2)
  loyaltyDiscountPct Int?
  actionId           String?
  action             Action?  @relation(fields: [actionId], references: [id])

  // PDP expandable information sections
  pdpDeliveryTerms     String? @db.Text
  declaration          String? @db.Text
  assemblyInstructions String? @db.Text
  maintenance          String? @db.Text
  technicalSpecs       Json?
  warrantyYears        Int?
  countryOfOrigin      String?

  // Flags
  isHero    Boolean   @default(false)
  isNew     Boolean   @default(false)
  newUntil  DateTime?
  isLimited Boolean   @default(false)
  /// "Dok traju zalihe"
  isDtz     Boolean   @default(false)

  // Stock
  stock                 Int       @default(0)
  incomingStock         Int       @default(0)
  supplierStock         Int?
  /// Supplier quantity already committed to active customer orders.
  supplierReservedStock Int       @default(0)
  supplierNextArrivalAt DateTime?

  // ERP cost of goods sold (weighted-average, computed on goods receipt). Spec §5.1.
  cogs        Decimal? @db.Decimal(12, 2)
  // Customs rate used in purchase-order BM% calc (spec §4.1.1).
  customsRate Decimal? @db.Decimal(8, 2)

  // Manual sales-channel availability checks (auto status is derived from stock).
  availableWebManual       Boolean @default(true)
  availableWholesaleManual Boolean @default(true)
  availableExportManual    Boolean @default(true)
  /// Denormalized live availability in the default distribution centre.
  dcAvailableQty           Int     @default(0)
  availableWebAuto         Boolean @default(false)
  availableWholesaleAuto   Boolean @default(false)
  availableExportAuto      Boolean @default(false)

  // Delivery / assembly
  deliveryDaysMin Int     @default(3)
  deliveryDaysMax Int     @default(5)
  allowsAssembly  Boolean @default(false)

  // Supplier link (XML feed origin)
  supplierId         String?
  supplier           Supplier? @relation(fields: [supplierId], references: [id])
  supplierExternalId String?
  /// Field-level admin overrides that XML imports must not overwrite.
  /// Shape: { fields: ["name", "description", "media", ...], updatedBy, updatedAt }
  syncOverrides      Json?
  supplierApprovalStatus SupplierProductApprovalStatus?
  supplierApprovedAt     DateTime?
  supplierApprovedById   String?
  supplierCatalogMissingCount Int       @default(0)
  supplierCatalogMissingSince DateTime?
  supplierStockMissingCount   Int       @default(0)
  supplierStockMissingSince   DateTime?
  lastSupplierSyncAt          DateTime?
  lastSupplierSourceHash      String?

  // Ads
  inGoogleMerchant Boolean @default(false)
  inMetaCatalog    Boolean @default(false)
  inTiktokCatalog  Boolean @default(false)

  // Availability flag (auto-set false when stock=0 && incomingStock=0)
  isActive Boolean @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  categories               ProductCategory[]
  media                    ProductMedia[]
  attachments              ProductAttachment[]
  pictograms               ProductPictogram[]
  materials                ProductMaterial[]
  variants                 Variant[]
  assemblyCities           ProductAssemblyCity[]
  deliveryRules            DeliveryPriceRule[]
  recommendedBy            RecommendationRule[]      @relation("RecommendationRuleProducts")
  orderItems               OrderItem[]
  purchasePrices           PurchasePrice[]
  purchaseOrderItems       PurchaseOrderItem[]
  inboundInvoiceItems      InboundInvoiceItem[]
  retailPriceProposals     RetailPriceProposal[]
  wishlistItems            WishlistItem[]
  backInStockAlerts        BackInStockAlert[]
  onSaleAlerts             OnSaleAlert[]
  reclamations             Reclamation[]
  stockSnapshots           SupplierStockSnapshot[]
  warehouseStocks          WarehouseStock[]
  stockMovements           StockMovement[]
  fiscalDocumentLines      FiscalDocumentLine[]
  lookupAssignments        ProductLookupAssignment[]
  priceListEntries         PriceListEntry[]
  actionPrices             ActionProduct[]
  loyaltyPriceHistory      LoyaltyPriceHistory[]
  dispatchNoteItems        DispatchNoteItem[]
  partnerReservations      PartnerReservation[]
  stockCountItems          StockCountItem[]
  analyticsEvents          AnalyticsEvent[]
  supplierFulfillmentItems SupplierFulfillmentItem[]
  supplierSyncChanges      SupplierSyncChange[]

  @@unique([supplierId, supplierExternalId])
  @@index([slug])
  @@index([sku])
  @@index([barcode])
  @@index([isActive, isHero])
  @@index([groupId])
  @@index([collectionId])
  @@index([supplierId])
  @@index([supplierId, supplierApprovalStatus])
}

model ArticleSequence {
  year      Int      @id
  lastValue Int      @default(0)
  updatedAt DateTime @updatedAt
}

model ProductCategory {
  productId  String
  categoryId String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([productId, categoryId])
  @@index([categoryId])
}

model Variant {
  id         String   @id @default(cuid())
  productId  String
  sku        String   @unique
  /// e.g. color, size descriptor
  name       String
  /// Color hex if applicable
  colorHex   String?
  stock      Int      @default(0)
  pricedelta Decimal? @db.Decimal(12, 2)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

enum MediaKind {
  IMAGE
  VIDEO
  VIDEO_3D
}

enum ProductAssetSyncStatus {
  READY
  PENDING
  FAILED
}

model ProductMedia {
  id          String                 @id @default(cuid())
  productId   String
  kind        MediaKind              @default(IMAGE)
  url         String
  sourceUrl   String?
  syncStatus  ProductAssetSyncStatus @default(READY)
  thumbUrl    String?
  cardUrl     String?
  pdpUrl      String?
  alt         String?
  width       Int?
  height      Int?
  blurDataUrl String?
  order       Int                    @default(0)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, order])
  @@index([syncStatus])
}

enum ProductAttachmentKind {
  MANUAL
  ENERGY_LABEL
}

model ProductAttachment {
  id         String                 @id @default(cuid())
  productId  String
  kind       ProductAttachmentKind
  label      String
  url        String
  sourceUrl  String?
  syncStatus ProductAssetSyncStatus @default(READY)
  order      Int                    @default(0)
  createdAt  DateTime               @default(now())
  updatedAt  DateTime               @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, kind, order])
  @@index([productId, order])
  @@index([syncStatus])
}

model Pictogram {
  id      String @id @default(cuid())
  code    String @unique
  label   String
  iconUrl String

  products   ProductPictogram[]
  placements PictogramPlacement[]
}

model ProductPictogram {
  productId   String
  pictogramId String
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  pictogram   Pictogram @relation(fields: [pictogramId], references: [id], onDelete: Cascade)

  @@id([productId, pictogramId])
}

model Material {
  id       String  @id @default(cuid())
  slug     String  @unique
  label    String
  imageUrl String?

  products ProductMaterial[]
}

model ProductMaterial {
  productId  String
  materialId String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  material   Material @relation(fields: [materialId], references: [id], onDelete: Cascade)

  @@id([productId, materialId])
}

model ProductAssemblyCity {
  productId String
  cityId    String
  product   Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  city      DeliveryCity @relation(fields: [cityId], references: [id], onDelete: Cascade)

  @@id([productId, cityId])
}

// ──────────────────────────────────────────────────────────────────────
// 3. Promo (banners, bar, tabs, actions, vouchers, ads, recs)
// ──────────────────────────────────────────────────────────────────────

enum BannerPlacement {
  HERO
  HOME_AFTER_SECOND_ROW
  HOME_AFTER_FOURTH_ROW
}

model Banner {
  id           String          @id @default(cuid())
  title        String
  subtitle     String?
  ctaLabel     String?
  ctaHref      String?
  imageDesktop String
  imageMobile  String?
  startsAt     DateTime?
  endsAt       DateTime?
  order        Int             @default(0)
  enabled      Boolean         @default(true)
  placement    BannerPlacement @default(HERO)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([enabled, placement, order])
}

model PromoBar {
  id        String    @id @default(cuid())
  enabled   Boolean   @default(true)
  text      String
  href      String?
  startsAt  DateTime?
  endsAt    DateTime?
  updatedAt DateTime  @updatedAt
}

model Tab {
  id      String  @id @default(cuid())
  label   String
  href    String
  order   Int     @default(0)
  icon    String?
  enabled Boolean @default(true)

  @@index([enabled, order])
}

enum HomeSectionSlotKey {
  FIRST
  SECOND
  THIRD
  FOURTH
  FIFTH
  SIXTH
}

enum HomeSectionSourceType {
  ACTION
  LANDING_PAGE
}

enum ActionKind {
  AKCIJA
  NEDELJNA
  HEROJI
  OGRANICENA
  OUTLET
  CUSTOM
}

model Action {
  id          String     @id @default(cuid())
  slug        String     @unique
  name        String
  kind        ActionKind @default(CUSTOM)
  startsAt    DateTime
  endsAt      DateTime
  isHero      Boolean    @default(false)
  /// Permanent protected-price campaign ("Trajno niska cena").
  isPermanent Boolean    @default(false)
  /// Admin-controlled sort order override
  sortOrder   Int        @default(0)
  priority    Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  products            Product[]
  heroes              HeroOfMonth[]
  homepageSlots       HomeSectionSlot[]
  actionPrices        ActionProduct[]
  pictogramPlacements PictogramPlacement[]
  mobileTabs          MobileTab[]

  @@index([startsAt, endsAt])
}

model HomeSectionSlot {
  id             String                @id @default(cuid())
  slotKey        HomeSectionSlotKey    @unique
  sourceType     HomeSectionSourceType
  actionId       String?
  landingPageKey String?
  titleOverride  String?
  productLimit   Int                   @default(12)
  enabled        Boolean               @default(true)
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  action Action? @relation(fields: [actionId], references: [id], onDelete: SetNull)

  @@index([enabled, slotKey])
  @@index([actionId])
}

model HeroOfMonth {
  id         String  @id @default(cuid())
  actionId   String?
  productSku String
  month      Int // 1-12
  year       Int
  order      Int     @default(0)

  action Action? @relation(fields: [actionId], references: [id])

  @@unique([productSku, month, year])
  @@index([year, month])
}

enum VoucherKind {
  PERCENT
  FIXED
}

model Voucher {
  code         String      @id
  kind         VoucherKind
  amount       Decimal     @db.Decimal(12, 2)
  minSubtotal  Decimal?    @db.Decimal(12, 2)
  startsAt     DateTime?
  endsAt       DateTime?
  usageLimit   Int?
  perUserLimit Int?
  active       Boolean     @default(true)
  createdAt    DateTime    @default(now())

  redemptions VoucherRedemption[]
}

model VoucherRedemption {
  id          String   @id @default(cuid())
  voucherCode String
  userId      String?
  orderId     String?  @unique
  amount      Decimal  @db.Decimal(12, 2)
  createdAt   DateTime @default(now())

  voucher Voucher @relation(fields: [voucherCode], references: [code])
  user    User?   @relation(fields: [userId], references: [id])
  order   Order?  @relation(fields: [orderId], references: [id])

  @@index([userId])
}

enum AdChannel {
  GOOGLE_MERCHANT
  META
  TIKTOK
}

model AdFlag {
  id        String    @id @default(cuid())
  channel   AdChannel
  enabled   Boolean   @default(true)
  budgetRsd Decimal?  @db.Decimal(12, 2)
  updatedAt DateTime  @updatedAt

  @@unique([channel])
}

/// Per-group cross-sell rules ("predlog kupovine" modal contents)
model RecommendationRule {
  id       String    @id @default(cuid())
  groupId  String
  group    Group     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  /// Ordered SKUs to surface; products linked via M:N join
  products Product[] @relation("RecommendationRuleProducts")
  order    Int       @default(0)
  enabled  Boolean   @default(true)

  @@index([groupId])
}

// ──────────────────────────────────────────────────────────────────────
// 4. Stock & supply
// ──────────────────────────────────────────────────────────────────────

enum SupplierFulfillmentMode {
  NONE
  EMAIL
  HTTP
}

model Supplier {
  id                 String                  @id @default(cuid())
  name               String                  @unique
  integrationKey     String?                 @unique
  feedUrl            String?
  catalogFallbackUrl String?
  authUser           String?
  authPass           String?
  stockFeedUrl       String?
  stockAuthUser      String?
  stockAuthPass      String?
  fulfillmentMode    SupplierFulfillmentMode @default(NONE)
  reservationUrl     String?
  enabled            Boolean                 @default(true)
  notes              String?                 @db.Text

  // ERP supplier master data (spec §2 - Maticni podaci o dobavljacima).
  code               String?     @unique
  address            String?
  city               String?
  country            String?     @default("RS")
  email              String?
  phone              String?
  currency           ErpCurrency @default(RSD)
  parity             String?
  paymentTerms       String?
  deliveryDays       Int?
  transitDays        Int?
  bank               String?
  swift              String?
  iban               String?
  defaultPriceListId String?
  /// Phase 4A — per-supplier `SupplierFeedMapping` JSON. Defines the XML
  /// path expressions used by the importer to project vendor XML into the
  /// canonical `FeedItem` shape. Null = supplier not yet configured.
  mapping            Json?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  products         Product[]
  purchasePrices   PurchasePrice[]
  purchaseOrders   PurchaseOrder[]
  inboundInvoices  InboundInvoice[]
  importRuns       ImportRun[]
  snapshots        SupplierStockSnapshot[]
  safetyRules      SafetyStockRule[]
  loadingLocations SupplierLoadingLocation[]
  fulfillments     SupplierFulfillment[]
  syncLeases       SupplierSyncLease[]
  categoryMappings SupplierCategoryMapping[]
  syncChanges      SupplierSyncChange[]
  defaultPriceList PriceList?                @relation("SupplierDefaultPriceList", fields: [defaultPriceListId], references: [id], onDelete: SetNull)
}

model SupplierStockSnapshot {
  id            String   @id @default(cuid())
  supplierId    String
  productId     String?
  externalSku   String
  stock         Int
  incomingStock Int      @default(0)
  capturedAt    DateTime @default(now())

  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  product  Product? @relation(fields: [productId], references: [id])

  @@index([supplierId, capturedAt])
  @@index([externalSku])
}

model SafetyStockRule {
  id           String  @id @default(cuid())
  supplierId   String?
  /// Optional category scope
  categoryPath String?
  /// Disable product if effective stock falls below this
  threshold    Int     @default(0)

  supplier Supplier? @relation(fields: [supplierId], references: [id], onDelete: Cascade)
}

enum ImportStatus {
  RUNNING
  SUCCESS
  PARTIAL
  FAILED
}

enum ImportKind {
  GENERIC
  CATALOG
  STOCK
  MEDIA
}

model ImportRun {
  id           String       @id @default(cuid())
  supplierId   String
  kind         ImportKind   @default(GENERIC)
  dryRun       Boolean      @default(false)
  startedAt    DateTime     @default(now())
  finishedAt   DateTime?
  status       ImportStatus @default(RUNNING)
  recordsRead  Int          @default(0)
  recordsOk    Int          @default(0)
  recordsFail  Int          @default(0)
  errorMessage String?      @db.Text
  errors       Json?
  metadata     Json?
  sourceHash   String?
  heartbeatAt  DateTime?
  previewRunId String?
  requestedById String?
  rollbackOfId  String?

  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  changes SupplierSyncChange[]

  @@index([supplierId, startedAt])
  @@index([supplierId, kind, status, startedAt])
}

/// Renewable lease used to prevent cron and administrators from running the
/// same supplier sync concurrently. Acquisition is performed atomically.
model SupplierSyncLease {
  supplierId String
  scope      String   @db.VarChar(32)
  ownerRunId String
  acquiredAt DateTime @default(now())
  heartbeatAt DateTime @default(now())
  expiresAt  DateTime

  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@id([supplierId, scope])
  @@index([expiresAt])
}

/// Explicit supplier taxonomy mapping. Unknown feed categories stay pending
/// instead of silently creating a public storefront taxonomy.
model SupplierCategoryMapping {
  id               String   @id @default(cuid())
  supplierId       String
  externalCategory String
  externalType     String
  categoryId       String
  enabled          Boolean  @default(true)
  createdById      String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  @@unique([supplierId, externalCategory, externalType])
  @@index([categoryId])
}

/// Per-product before/after ledger for previews, proposals, conflict review,
/// applied batches and field-level rollback.
model SupplierSyncChange {
  id           String                   @id @default(cuid())
  supplierId   String
  importRunId  String
  productId    String?
  externalSku  String
  changeType   String                   @db.VarChar(40)
  status       SupplierSyncChangeStatus @default(PREVIEW)
  fieldNames   String[]
  before       Json?
  after        Json?
  reversible   Boolean                  @default(true)
  reason       String?                  @db.Text
  appliedAt    DateTime?
  revertedAt   DateTime?
  reviewedById String?
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt

  supplier  Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  importRun ImportRun @relation(fields: [importRunId], references: [id], onDelete: Cascade)
  product   Product?  @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([importRunId, status])
  @@index([supplierId, status, createdAt])
  @@index([productId, createdAt])
  @@index([externalSku])
}

// ──────────────────────────────────────────────────────────────────────
