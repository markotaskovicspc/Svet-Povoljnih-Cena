  createdAt          DateTime @default(now())

  fiscalDocument   FiscalDocument       @relation(fields: [fiscalDocumentId], references: [id], onDelete: Cascade)
  orderItem        OrderItem?           @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  product          Product?             @relation(fields: [productId], references: [id], onDelete: SetNull)
  originalSaleLine FiscalDocumentLine?  @relation("FiscalLineRefunds", fields: [originalSaleLineId], references: [id], onDelete: SetNull)
  refundLines      FiscalDocumentLine[] @relation("FiscalLineRefunds")

  @@index([fiscalDocumentId])
  @@index([orderItemId])
  @@index([productId])
  @@index([originalSaleLineId])
  @@index([sku])
}

model FiscalProductSync {
  id           String   @id @default(cuid())
  provider     String   @default("badi")
  sku          String
  name         String
  taxRateLabel String   @default("Ђ")
  isService    Boolean  @default(false)
  providerId   String?
  /// badi-assigned NUMERIC sku; receipt items must reference this, not the internal string `sku`.
  providerSku  Int?
  syncedAt     DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([provider, sku])
  @@index([sku])
}

model Warehouse {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  isDefault Boolean  @default(false)
  active    Boolean  @default(true)
  address   String?
  city      String?
  email     String?
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stocks                  WarehouseStock[]
  movements               StockMovement[]
  fiscalDocuments         FiscalDocument[]
  orderItems              OrderItem[]
  purchaseOrdersReceiving PurchaseOrder[]  @relation("PurchaseOrderReceivingWarehouse")
  outgoingDispatchNotes   DispatchNote[]   @relation("DispatchSourceWarehouse")
  incomingDispatchNotes   DispatchNote[]   @relation("DispatchDestinationWarehouse")
  stockCounts             StockCount[]
  partnerReservations     PartnerReservation[]

  @@index([active, isDefault])
}

model WarehouseStock {
  id          String   @id @default(cuid())
  warehouseId String
  productId   String
  qty         Int      @default(0)
  updatedAt   DateTime @updatedAt

  warehouse Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([warehouseId, productId])
  @@index([productId])
}

model StockMovement {
  id                    String            @id @default(cuid())
  idempotencyKey        String?           @unique
  warehouseId           String
  productId             String?
  orderId               String?
  orderItemId           String?
  fiscalDocumentId      String?
  kind                  StockMovementKind
  sku                   String
  qty                   Int
  note                  String?           @db.Text
  actorId               String?
  balanceAfterWarehouse Int?
  balanceAfterTotal     Int?
  createdAt             DateTime          @default(now())

  warehouse      Warehouse       @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  product        Product?        @relation(fields: [productId], references: [id], onDelete: SetNull)
  order          Order?          @relation(fields: [orderId], references: [id], onDelete: SetNull)
  orderItem      OrderItem?      @relation(fields: [orderItemId], references: [id], onDelete: SetNull)
  fiscalDocument FiscalDocument? @relation(fields: [fiscalDocumentId], references: [id], onDelete: SetNull)

  @@index([warehouseId, createdAt])
  @@index([productId])
  @@index([orderId])
  @@index([fiscalDocumentId])
  @@index([sku])
}

model PaymentRefund {
  id               String              @id @default(cuid())
  idempotencyKey   String?             @unique @db.VarChar(200)
  orderId          String
  fiscalDocumentId String?
  method           PaymentMethod
  provider         PaymentProvider     @default(MANUAL)
  status           PaymentRefundStatus @default(PENDING)
  amount           Decimal             @db.Decimal(12, 2)
  currency         String              @default("RSD")
  providerRef      String?
  rawRequest       Json?
  rawResponse      Json?
  error            String?             @db.Text
  actorId          String?
  completedAt      DateTime?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  order          Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  fiscalDocument FiscalDocument? @relation(fields: [fiscalDocumentId], references: [id], onDelete: SetNull)

  @@index([orderId, createdAt])
  @@index([fiscalDocumentId])
  @@index([method, status])
}

// ──────────────────────────────────────────────────────────────────────
// 6b. ERP purchasing and inbound finance foundation
// ──────────────────────────────────────────────────────────────────────

enum ErpCurrency {
  RSD
  EUR
  USD
}

enum PurchaseOrderStatus {
  DRAFT
  SENT
  CONFIRMED
  RECEIVED
  CANCELLED
}

enum InboundInvoiceType {
  DOM
  INO
  COGS
}

enum InboundInvoiceStatus {
  DRAFT
  RECEIVED
  POSTED
  CANCELLED
}

enum CogsStatus {
  PENDING
  CALCULATED
  LOCKED
}

model PurchasePrice {
  id         String      @id @default(cuid())
  productId  String?
  supplierId String?
  sku        String
  name       String?
  attributes String?
  pattern    String?
  price      Decimal     @db.Decimal(12, 2)
  currency   ErpCurrency @default(RSD)
  parity     String?
  validFrom  DateTime
  validTo    DateTime?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  product  Product?  @relation(fields: [productId], references: [id], onDelete: SetNull)
  supplier Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)

  @@index([sku])
  @@index([supplierId, validFrom])
  @@index([productId, validFrom])
}

model PurchaseOrder {
  id                   String              @id @default(cuid())
  number               String              @unique
  status               PurchaseOrderStatus @default(DRAFT)
  supplierId           String?
  loadingLocationId    String?
  receivingWarehouseId String?
  transportTypeId      String?
  orderDate            DateTime?
  loadingDate          DateTime?
  deliveryDate         DateTime?
  totalVolume          Decimal?            @db.Decimal(12, 3)
  totalWeight          Decimal?            @db.Decimal(12, 3)
  totalPrice           Decimal             @default(0) @db.Decimal(12, 2)
  freightCost          Decimal             @default(0) @db.Decimal(12, 2)
  currency             ErpCurrency         @default(RSD)
  exchangeRate         Decimal             @default(1) @db.Decimal(14, 6)
  freightCurrency      ErpCurrency         @default(RSD)
  freightExchangeRate  Decimal             @default(1) @db.Decimal(14, 6)
  allocationBasis      AllocationBasis     @default(AUTO_UTILIZATION)
  transportType        String?
  parity               String?
  bmPct                Decimal?            @db.Decimal(8, 2)
  pdfUrl               String?
  notes                String?             @db.Text
  lockedAt             DateTime?
  postedAt             DateTime?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  supplier            Supplier?                  @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  loadingLocation     SupplierLoadingLocation?   @relation(fields: [loadingLocationId], references: [id], onDelete: SetNull)
  receivingWarehouse  Warehouse?                 @relation("PurchaseOrderReceivingWarehouse", fields: [receivingWarehouseId], references: [id], onDelete: SetNull)
  transportDefinition TransportType?             @relation(fields: [transportTypeId], references: [id], onDelete: SetNull)
  items               PurchaseOrderItem[]
  events              PurchaseOrderStatusEvent[]
  inboundInvoices     InboundInvoice[]

  @@index([supplierId, createdAt])
  @@index([status, createdAt])
}

model PurchaseOrderItem {
  id                      String      @id @default(cuid())
  purchaseOrderId         String
  productId               String?
  sku                     String
  name                    String
  attributes              String?
  pattern                 String?
  purchasePrice           Decimal     @db.Decimal(12, 2)
  currency                ErpCurrency @default(RSD)
  parity                  String?
  moq                     Int?
  packQty                 Int?
  qty                     Int
  receivedQty             Int         @default(0)
  totalVolume             Decimal?    @db.Decimal(12, 3)
  totalWeight             Decimal?    @db.Decimal(12, 3)
  customsRate             Decimal?    @db.Decimal(8, 2)
  calcRetailPrice         Decimal?    @db.Decimal(12, 2)
  bmPct                   Decimal?    @db.Decimal(8, 2)
  freightAllocated        Decimal?    @db.Decimal(12, 2)
  additionalCostAllocated Decimal?    @db.Decimal(12, 2)
  priceValidFrom          DateTime?
  supplierProductName     String?
  certificates            String?
  barcode                 String?
  createdAt               DateTime    @default(now())
  updatedAt               DateTime    @updatedAt

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  product       Product?      @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([purchaseOrderId])
  @@index([sku])
  @@index([productId])
}

model PurchaseOrderStatusEvent {
  id              String              @id @default(cuid())
  purchaseOrderId String
  status          PurchaseOrderStatus
  note            String?             @db.Text
  actorId         String?
  createdAt       DateTime            @default(now())

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  @@index([purchaseOrderId, createdAt])
}

model InboundInvoice {
  id              String               @id @default(cuid())
  number          String               @unique
  type            InboundInvoiceType
  supplierId      String?
  purchaseOrderId String?
  status          InboundInvoiceStatus @default(DRAFT)
  invoiceDate     DateTime?
  currency        ErpCurrency          @default(RSD)
  exchangeRate    Decimal              @default(1) @db.Decimal(14, 6)
  value           Decimal              @default(0) @db.Decimal(12, 2)
  netValue        Decimal              @default(0) @db.Decimal(12, 2)
  vatValue        Decimal              @default(0) @db.Decimal(12, 2)
  grossValue      Decimal              @default(0) @db.Decimal(12, 2)
  allocationBasis AllocationBasis      @default(AUTO_UTILIZATION)
  cogsStatus      CogsStatus           @default(PENDING)
  notes           String?              @db.Text
  lockedAt        DateTime?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  supplier      Supplier?            @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  purchaseOrder PurchaseOrder?       @relation(fields: [purchaseOrderId], references: [id], onDelete: SetNull)
  items         InboundInvoiceItem[]

  @@index([supplierId, invoiceDate])
  @@index([status, invoiceDate])
  @@index([purchaseOrderId])
}

model InboundInvoiceItem {
  id               String   @id @default(cuid())
  inboundInvoiceId String
  productId        String?
  sku              String?
  name             String
  qty              Int      @default(1)
  unitPrice        Decimal  @db.Decimal(12, 2)
  total            Decimal  @db.Decimal(12, 2)
  createdAt        DateTime @default(now())

  inboundInvoice InboundInvoice @relation(fields: [inboundInvoiceId], references: [id], onDelete: Cascade)
  product        Product?       @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([inboundInvoiceId])
  @@index([sku])
  @@index([productId])
}

enum RetailPriceProposalStatus {
  PREDLOG
  OBJAVLJENO
  ARHIVA
}

/// Retail-price (MPC) management — spec §6/§7. A proposal carries a new MPC with
/// optional validity window; publishing writes it onto the product and archives
/// any previously published proposal for the same SKU.
model RetailPriceProposal {
  id          String                    @id @default(cuid())
  productId   String?
  sku         String
  name        String?
  currentMpc  Decimal?                  @db.Decimal(12, 2)
  proposedMpc Decimal                   @db.Decimal(12, 2)
  bmPct       Decimal?                  @db.Decimal(8, 2)
  validFrom   DateTime?
  validTo     DateTime?
  status      RetailPriceProposalStatus @default(PREDLOG)
  actorId     String?
  publishedAt DateTime?
  createdAt   DateTime                  @default(now())
  updatedAt   DateTime                  @updatedAt

  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([sku])
  @@index([status])
}

// ──────────────────────────────────────────────────────────────────────
// 6c. ERP master data, pricing, logistics, partners and analytics
// ──────────────────────────────────────────────────────────────────────

enum ProductLookupKind {
  ATTRIBUTE
  COLOR
  BENEFIT
  CERTIFICATE
}

model ProductLookupValue {
  id        String            @id @default(cuid())
  kind      ProductLookupKind
  value     String
  slug      String
  active    Boolean           @default(true)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  assignments ProductLookupAssignment[]

  @@unique([kind, value])
  @@unique([kind, slug])
  @@index([kind, active, value])
}

model ProductLookupAssignment {
  productId     String
  lookupValueId String
  product       Product            @relation(fields: [productId], references: [id], onDelete: Cascade)
  lookupValue   ProductLookupValue @relation(fields: [lookupValueId], references: [id], onDelete: Cascade)

  @@id([productId, lookupValueId])
  @@index([lookupValueId])
}

model SupplierLoadingLocation {
  id         String   @id @default(cuid())
  supplierId String
  name       String
  address    String?
  city       String?
  country    String   @default("RS")
  position   Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  supplier       Supplier              @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  purchaseOrders PurchaseOrder[]
  fulfillments   SupplierFulfillment[]

  @@unique([supplierId, position])
  @@index([supplierId, name])
}

enum SupplierFulfillmentStatus {
  PENDING
  SENT
  CONFIRMED
  PICKUP_READY
  CANCELLED
  COMPLETED
  FAILED
}

model SupplierFulfillment {
  id                    String                    @id @default(cuid())
  orderId               String
  supplierId            String
  loadingLocationId     String?
  status                SupplierFulfillmentStatus @default(PENDING)
  sentAt                DateTime?
  confirmedAt           DateTime?
  cancelledAt           DateTime?
  completedAt           DateTime?
  reservationReleasedAt DateTime?
  lastError             String?                   @db.Text
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt

  order           Order                     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  supplier        Supplier                  @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  loadingLocation SupplierLoadingLocation?  @relation(fields: [loadingLocationId], references: [id], onDelete: SetNull)
  items           SupplierFulfillmentItem[]

  @@unique([orderId, supplierId])
  @@index([supplierId, status, createdAt])
  @@index([loadingLocationId])
}

model SupplierFulfillmentItem {
  id            String  @id @default(cuid())
  fulfillmentId String
  orderItemId   String  @unique
  productId     String?
  externalSku   String
  qty           Int

  fulfillment SupplierFulfillment @relation(fields: [fulfillmentId], references: [id], onDelete: Cascade)
  orderItem   OrderItem           @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  product     Product?            @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([fulfillmentId])
  @@index([productId])
  @@index([externalSku])
}

model TransportType {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  payloadKg Decimal? @db.Decimal(12, 3)
  payloadM3 Decimal? @db.Decimal(12, 3)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  purchaseOrders PurchaseOrder[]
}

model ExchangeRateSnapshot {
  id            String      @id @default(cuid())
  baseCurrency  ErpCurrency @default(RSD)
  quoteCurrency ErpCurrency
  rate          Decimal     @db.Decimal(14, 6)
  validAt       DateTime
  source        String
  createdAt     DateTime    @default(now())

  @@unique([baseCurrency, quoteCurrency, validAt, source])
  @@index([quoteCurrency, validAt])
}

enum AllocationBasis {
  AUTO_UTILIZATION
  VALUE
  WEIGHT
  VOLUME
  MANUAL
}

enum PriceListKind {
  RETAIL
  PURCHASE
  WHOLESALE
  EXPORT
}

model PriceList {
  id        String        @id @default(cuid())
  code      String        @unique
  name      String
  kind      PriceListKind
  currency  ErpCurrency   @default(RSD)
  active    Boolean       @default(true)
  validFrom DateTime?
  validTo   DateTime?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  entries             PriceListEntry[]
  orders              Order[]
  defaultForSuppliers Supplier[]       @relation("SupplierDefaultPriceList")

  @@index([kind, active, validFrom])
}

model PriceListEntry {
  id          String    @id @default(cuid())
  priceListId String
  productId   String
  price       Decimal   @db.Decimal(12, 2)
  validFrom   DateTime
  validTo     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  priceList PriceList @relation(fields: [priceListId], references: [id], onDelete: Cascade)
  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([priceListId, productId, validFrom])
  @@index([productId, validFrom, validTo])
}

model ActionProduct {
  actionId  String
  productId String
  salePrice Decimal  @db.Decimal(12, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  action  Action  @relation(fields: [actionId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([actionId, productId])
  @@index([productId])
}

model LoyaltyRule {
  id          String    @id @default(cuid())
  name        String
  discountPct Decimal   @db.Decimal(8, 2)
  priority    Int       @default(0)
  startsAt    DateTime?
  endsAt      DateTime?
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([active, priority, startsAt, endsAt])
}

model LoyaltyPriceHistory {
  id        String   @id @default(cuid())
  productId String
  oldPrice  Decimal? @db.Decimal(12, 2)
  newPrice  Decimal? @db.Decimal(12, 2)
  actorId   String?
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, createdAt])
}

enum DiscountTarget {
  ALL
  CATEGORY
  GROUP
}

model LinearPromotion {
  id          String         @id @default(cuid())
  name        String
  discountPct Decimal        @db.Decimal(8, 2)
  target      DiscountTarget @default(ALL)
  priority    Int            @default(0)
  startsAt    DateTime
  endsAt      DateTime
  active      Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  categories LinearPromotionCategory[]
  groups     LinearPromotionGroup[]

  @@index([active, priority, startsAt, endsAt])
}

model LinearPromotionCategory {
  promotionId String
  categoryId  String
  promotion   LinearPromotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  category    Category        @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([promotionId, categoryId])
  @@index([categoryId])
}

model LinearPromotionGroup {
  promotionId String
  groupId     String
  promotion   LinearPromotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  group       Group           @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@id([promotionId, groupId])
  @@index([groupId])
}

enum CustomerGender {
  NEPOZNATO
  ZENSKI
  MUSKI
}

model Customer {
  id          String         @id @default(cuid())
  userId      String?        @unique
  firstName   String?
  lastName    String?
  companyName String?
  pib         String?
  address     String?
  city        String?
  postalCode  String?
  country     String         @default("RS")
  phone       String?
  email       String?
  gender      CustomerGender @default(NEPOZNATO)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  orders Order[]

  @@index([email])
  @@index([phone])
  @@index([pib])
  @@index([createdAt])
}

enum DispatchNoteType {
  CUSTOMER
  INTERNAL
  STOCKTAKE
}

enum DocumentPostingStatus {
  DRAFT
  POSTED
  CANCELLED
}

model DispatchNote {
  id                     String                @id @default(cuid())
  number                 String                @unique
  type                   DispatchNoteType      @default(CUSTOMER)
  status                 DocumentPostingStatus @default(DRAFT)
  orderId                String?
  sourceWarehouseId      String
  destinationWarehouseId String?
  destinationName        String?
  destinationAddress     String?
  destinationCity        String?
  notes                  String?               @db.Text
  postedAt               DateTime?
  actorId                String?
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt

  order                Order?             @relation(fields: [orderId], references: [id], onDelete: SetNull)
  sourceWarehouse      Warehouse          @relation("DispatchSourceWarehouse", fields: [sourceWarehouseId], references: [id])
  destinationWarehouse Warehouse?         @relation("DispatchDestinationWarehouse", fields: [destinationWarehouseId], references: [id], onDelete: SetNull)
  items                DispatchNoteItem[]

  @@index([orderId])
  @@index([status, createdAt])
  @@index([sourceWarehouseId, createdAt])
}

model DispatchNoteItem {
  id             String  @id @default(cuid())
  dispatchNoteId String
  orderItemId    String?
  productId      String?
  sku            String
  name           String
  qty            Int

  dispatchNote DispatchNote @relation(fields: [dispatchNoteId], references: [id], onDelete: Cascade)
  orderItem    OrderItem?   @relation(fields: [orderItemId], references: [id], onDelete: SetNull)
  product      Product?     @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([dispatchNoteId])
  @@index([orderItemId])
  @@index([productId])
}

enum PickupBatchStatus {
  DRAFT
  BOOKED
  PICKED_UP
  CANCELLED
}

model PickupBatch {
  id                 String            @id @default(cuid())
  number             String            @unique
  courier            ShipmentService?
  status             PickupBatchStatus @default(DRAFT)
  manifestRef        String?
  pickupDate         DateTime?
  configurationIssue String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  lines PickupBatchLine[]

  @@index([status, pickupDate])
}

model PickupBatchLine {
  id          String   @id @default(cuid())
  batchId     String
  orderId     String
  orderItemId String?
  packageNo   Int      @default(1)
  weightKg    Decimal? @db.Decimal(10, 3)
  widthCm     Decimal? @db.Decimal(8, 2)
  depthCm     Decimal? @db.Decimal(8, 2)
  heightCm    Decimal? @db.Decimal(8, 2)

  batch     PickupBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  order     Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderItem OrderItem?  @relation(fields: [orderItemId], references: [id], onDelete: SetNull)

  @@unique([batchId, orderId, packageNo])
  @@index([orderId])
  @@index([orderItemId])
}

model PartnerApiClient {
  id         String    @id @default(cuid())
  name       String
  keyPrefix  String    @unique
  keyHash    String
  scopes     String[]
  rateLimit  Int       @default(120)
  enabled    Boolean   @default(true)
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  reservations PartnerReservation[]
}

enum PartnerReservationStatus {
  ACTIVE
  RELEASED
  CONSUMED
  CANCELLED
}

model PartnerReservation {
  id             String                   @id @default(cuid())
  clientId       String
  productId      String
  warehouseId    String?
  externalRef    String
  idempotencyKey String
  qty            Int
  status         PartnerReservationStatus @default(ACTIVE)
  expiresAt      DateTime?
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt

  client  PartnerApiClient @relation(fields: [clientId], references: [id], onDelete: Cascade)
  product Product          @relation(fields: [productId], references: [id])
  warehouse Warehouse?     @relation(fields: [warehouseId], references: [id], onDelete: SetNull)

  @@unique([clientId, idempotencyKey])
  @@unique([clientId, externalRef])
  @@index([productId, status])
  @@index([warehouseId, status])
}

model StockCount {
  id          String                @id @default(cuid())
  number      String                @unique
  warehouseId String
  status      DocumentPostingStatus @default(DRAFT)
  countedAt   DateTime?
  postedAt    DateTime?
  notes       String?               @db.Text
  actorId     String?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  warehouse Warehouse        @relation(fields: [warehouseId], references: [id])
  items     StockCountItem[]

  @@index([warehouseId, status, createdAt])
}

model StockCountItem {
  id            String @id @default(cuid())
  stockCountId  String
  productId     String
  expectedQty   Int
  countedQty    Int
  differenceQty Int

  stockCount StockCount @relation(fields: [stockCountId], references: [id], onDelete: Cascade)
  product    Product    @relation(fields: [productId], references: [id])

  @@unique([stockCountId, productId])
  @@index([productId])
}

enum LandingPageStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model LandingPage {
  id             String            @id @default(cuid())
  slug           String            @unique
  title          String
  lead           String?           @db.Text
  heroImageUrl   String?
  seoTitle       String?
  seoDescription String?           @db.Text
  status         LandingPageStatus @default(DRAFT)
  startsAt       DateTime?
  endsAt         DateTime?
  publishedAt    DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  sections            LandingPageSection[]
  pictogramPlacements PictogramPlacement[]
  mobileTabs          MobileTab[]

  @@index([status, publishedAt])
}

model LandingPageSection {
  id            String   @id @default(cuid())
  landingPageId String
  title         String?
  body          String?  @db.Text
  imageUrl      String?
  productSkus   String[]
  position      Int

  landingPage LandingPage @relation(fields: [landingPageId], references: [id], onDelete: Cascade)

  @@unique([landingPageId, position])
}

enum PictogramSlot {
  TOP_LEFT_1
  TOP_LEFT_2
  BOTTOM_RIGHT_1
  BOTTOM_RIGHT_2
}

model PictogramPlacement {
  id            String        @id @default(cuid())
  pictogramId   String
  actionId      String?
  landingPageId String?
  slot          PictogramSlot
  createdAt     DateTime      @default(now())

  pictogram   Pictogram    @relation(fields: [pictogramId], references: [id], onDelete: Cascade)
  action      Action?      @relation(fields: [actionId], references: [id], onDelete: Cascade)
  landingPage LandingPage? @relation(fields: [landingPageId], references: [id], onDelete: Cascade)

  @@index([actionId, slot])
  @@index([landingPageId, slot])
}

model MobileTab {
  id            String   @id @default(cuid())
  label         String
  icon          String?
  position      Int      @unique
  enabled       Boolean  @default(true)
  actionId      String?
  landingPageId String?
  href          String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  action      Action?      @relation(fields: [actionId], references: [id], onDelete: SetNull)
  landingPage LandingPage? @relation(fields: [landingPageId], references: [id], onDelete: SetNull)

  @@index([enabled, position])
}

enum AnalyticsEventType {
  PAGE_VIEW
  PRODUCT_VIEW
  ADD_TO_CART
  CHECKOUT_STARTED
  CHECKOUT_COMPLETED
}

model AnalyticsEvent {
  id             String             @id @default(cuid())
  type           AnalyticsEventType
  anonymousId    String
  sessionId      String?
  path           String?
  productId      String?
  orderId        String?
  quantity       Int?
  value          Decimal?           @db.Decimal(12, 2)
  consentVersion String
  metadata       Json?
  occurredAt     DateTime           @default(now())
  expiresAt      DateTime

  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  order   Order?   @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([type, occurredAt])
  @@index([anonymousId, occurredAt])
  @@index([productId, occurredAt])
  @@index([orderId])
  @@index([expiresAt])
}

enum IntegrationStatus {
  NOT_CONFIGURED
  UNHEALTHY
  HEALTHY
}

model IntegrationHealth {
  provider    String            @id
  status      IntegrationStatus @default(NOT_CONFIGURED)
  missingKeys String[]
  message     String?
  checkedAt   DateTime?
  updatedAt   DateTime          @updatedAt
}

model AdminSetting {
  key       String   @id
  value     Json
  updatedBy String?
  updatedAt DateTime @updatedAt
}

// ──────────────────────────────────────────────────────────────────────
// 7. Service (reclamations, comments, newsletter, viber)
// ──────────────────────────────────────────────────────────────────────

enum ReclamationStatus {
  PRIMLJENO
  U_OBRADI
  RESENO
  ODBIJENO
}

enum NotifyChannel {
  EMAIL
  PHONE
  SMS
  VIBER
}

enum ReclamationType {
  FIZICKO_OSTECENJE
  KVAR
}

enum ReclamationRequest {
  POPRAVKA
  ZAMENA
  POVRACAJ_NOVCA
  UMANJENJE_CENE
}

enum ReclamationDecision {
  CEKA
  PRIHVACENA
  ODBIJENA
}

enum ReclamationResolution {
  POVRAT_NOVCA
  ZAMENA_ARTIKLA
  ZAMENA_DELA
  POPUST
}

model Reclamation {
  id                        String                 @id @default(cuid())
  /// Public identifier R-{n}-{orderNo}
  number                    String                 @unique
  orderId                   String
  orderItemId               String?
  productId                 String?
  sku                       String
  customerFirst             String
  customerLast              String
  customerEmail             String?
  customerPhone             String?
  description               String                 @db.VarChar(250)
  notifyVia                 NotifyChannel
  status                    ReclamationStatus      @default(PRIMLJENO)
  purchaseDate              DateTime?
  type                      ReclamationType?
  request                   ReclamationRequest?
  decision                  ReclamationDecision    @default(CEKA)
  respondedAt               DateTime?
  resolution                ReclamationResolution?
  resolutionNote            String?                @db.Text
  adminNote                 String?                @db.Text
  courierRequestedAt        DateTime?
  warehouseRequestedAt      DateTime?
  supplierNotifiedAt        DateTime?
  supplierNotificationError String?                @db.Text
  userId                    String?
  createdAt                 DateTime               @default(now())
  resolvedAt                DateTime?

  order     Order                    @relation(fields: [orderId], references: [id])
  orderItem OrderItem?               @relation(fields: [orderItemId], references: [id], onDelete: SetNull)
  product   Product?                 @relation(fields: [productId], references: [id])
  user      User?                    @relation(fields: [userId], references: [id])
  photos    ReclamationPhoto[]
  events    ReclamationStatusEvent[]

  @@index([orderId])
  @@index([userId])
  @@index([status, resolvedAt])
  @@index([orderItemId])
}

model ReclamationPhoto {
  id            String @id @default(cuid())
  reclamationId String
  url           String
  width         Int?
  height        Int?
  bytes         Int?

  reclamation Reclamation @relation(fields: [reclamationId], references: [id], onDelete: Cascade)

  @@index([reclamationId])
}

model ReclamationStatusEvent {
  id            String            @id @default(cuid())
  reclamationId String
  status        ReclamationStatus
  note          String?           @db.Text
  actorId       String?
  createdAt     DateTime          @default(now())

  reclamation Reclamation @relation(fields: [reclamationId], references: [id], onDelete: Cascade)

  @@index([reclamationId, createdAt])
}

model Comment {
  id        String   @id @default(cuid())
  userId    String?
  name      String
  email     String
  subject   String?
  body      String   @db.Text
  createdAt DateTime @default(now())
  reviewed  Boolean  @default(false)

  user User? @relation(fields: [userId], references: [id])

  @@index([createdAt])
}

model NewsletterSubscriber {
  id             String    @id @default(cuid())
  email          String    @unique
  consent        Boolean   @default(true)
  source         String?
  createdAt      DateTime  @default(now())
  unsubscribedAt DateTime?
}

model NewsletterCampaign {
  id          String         @id @default(cuid())
  title       String
  subject     String
  body        String         @db.Text
  status      CampaignStatus @default(DRAFT)
  scheduledAt DateTime?
  sentAt      DateTime?
  recipients  Int?
  delivered   Int?
  failed      Int?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([status, scheduledAt])
}

model ViberAudienceQuery {
  id        String   @id @default(cuid())
  name      String
  /// Filter spec (cities, last-purchase range, etc.)
  filter    Json
  createdAt DateTime @default(now())

  campaigns ViberCampaign[]
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
  FAILED
}

model ViberCampaign {
  id          String         @id @default(cuid())
  audienceId  String
  title       String
  body        String         @db.Text
  imageUrl    String?
  ctaLabel    String?
  ctaUrl      String?
  status      CampaignStatus @default(DRAFT)
  scheduledAt DateTime?
  sentAt      DateTime?
  recipients  Int?
  delivered   Int?
  failed      Int?
  createdAt   DateTime       @default(now())

  audience ViberAudienceQuery @relation(fields: [audienceId], references: [id])

  @@index([status, scheduledAt])
}

model ViberWebhookEvent {
  id              String    @id @default(cuid())
  eventId         String    @unique
  event           String
  messageToken    String?
  campaignId      String?
  recipientUserId String?
  payload         Json
  receivedAt      DateTime  @default(now())
  appliedAt       DateTime?

  @@index([campaignId, receivedAt])
  @@index([event, receivedAt])
}

// ──────────────────────────────────────────────────────────────────────
// 8. Wishlist & alerts
// ──────────────────────────────────────────────────────────────────────

model WishlistItem {
  id              String   @id @default(cuid())
  userId          String
  productId       String
  notifyOnSale    Boolean  @default(false)
  notifyOnRestock Boolean  @default(false)
  addedAt         DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([productId])
}

model BackInStockAlert {
  id         String        @id @default(cuid())
  userId     String
  productId  String
  channel    NotifyChannel @default(EMAIL)
  createdAt  DateTime      @default(now())
  notifiedAt DateTime?

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId, channel])
  @@index([productId, notifiedAt])
}

model OnSaleAlert {
  id         String        @id @default(cuid())
  userId     String
  productId  String
  channel    NotifyChannel @default(EMAIL)
  createdAt  DateTime      @default(now())
  notifiedAt DateTime?

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId, channel])
  @@index([productId, notifiedAt])
}

// ──────────────────────────────────────────────────────────────────────
// 8. CMS content pages
// ──────────────────────────────────────────────────────────────────────

model ContentPage {
  id             String   @id @default(cuid())
  slug           String   @unique
  title          String
  lead           String?  @db.Text
  bodyMarkdown   String   @db.Text
  seoTitle       String?
  seoDescription String?  @db.Text
  published      Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([published, updatedAt])
}

// ──────────────────────────────────────────────────────────────────────
// 9. Admin
// ──────────────────────────────────────────────────────────────────────

enum AdminRoleName {
  SUPER
  CONTENT
  OPS
  ADS
}

model AdminUser {
  id           String        @id @default(cuid())
  email        String        @unique
  passwordHash String
  firstName    String?
  lastName     String?
  role         AdminRoleName @default(CONTENT)
  enabled      Boolean       @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  auditLogs  AuditLog[]
  savedViews AdminSavedView[]
}

model AdminSavedView {
  id          String   @id @default(cuid())
  adminUserId String
  module      String
  name        String
  query       Json
  filters     Json
  sorting     Json
  columns     Json
  pageSize    Int      @default(100)
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  adminUser AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)

  @@unique([adminUserId, module, name])
  @@index([adminUserId, module, isDefault])
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  action    String
  entity    String
  entityId  String?
  diff      Json?
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  actor AdminUser? @relation(fields: [actorId], references: [id])

  @@index([entity, entityId])
  @@index([createdAt])
}

/// Per-method toggle for the storefront checkout. Seeded with all
/// `PaymentMethod` enum values; admin flips `enabled` to hide a method from
/// the customer payment step without code changes.
model PaymentMethodConfig {
  method    PaymentMethod @id
  enabled   Boolean       @default(true)
  label     String?
  note      String?
  updatedAt DateTime      @updatedAt
}
