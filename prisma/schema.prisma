model Order {
  id                         String       @id @default(cuid())
  /// Human-friendly number e.g. "SPC-2026-001234"
  number                     String       @unique
  /// Hash of an opaque guest/public confirmation token.
  publicAccessTokenHash      String?      @unique
  publicAccessTokenCreatedAt DateTime?
  userId                     String?
  guestEmail                 String?
  status                     OrderStatus  @default(KREIRANO)
  channel                    SalesChannel @default(WEB)
  customerId                 String?
  priceListId                String?
  externalOrderNo            String?

  subtotal              Decimal  @db.Decimal(12, 2)
  savings               Decimal  @default(0) @db.Decimal(12, 2)
  shipping              Decimal  @default(0) @db.Decimal(12, 2)
  assemblyTotal         Decimal  @default(0) @db.Decimal(12, 2)
  voucherCode           String?
  voucherDiscount       Decimal? @db.Decimal(12, 2)
  /// First-purchase 5% (Phase 3D pricing engine).
  firstPurchaseDiscount Decimal? @db.Decimal(12, 2)
  /// Saved-card 5% (Phase 3D pricing engine).
  savedCardDiscount     Decimal? @db.Decimal(12, 2)
  total                 Decimal  @db.Decimal(12, 2)

  shippingMethod ShippingMethod
  paymentMethod  PaymentMethod

  // Snapshot addresses (denormalized so future address edits don't mutate history)
  shipFirstName              String
  shipLastName               String
  shipPhone                  String
  shipStreet                 String
  shipCity                   String
  shipPostalCode             String
  shipXExpressTownId         Int?
  shipXExpressStreetId       Int?
  shipCountry                String  @default("RS")
  shipCompanyName            String?
  shipPib                    String?
  glsDeliveryPointId         String?
  glsDeliveryPointName       String?
  glsDeliveryPointAddress    String?
  glsDeliveryPointCity       String?
  glsDeliveryPointPostalCode String?
  billingSameAsShipping      Boolean @default(true)
  billFirstName              String?
  billLastName               String?
  billStreet                 String?
  billCity                   String?
  billPostalCode             String?
  billXExpressTownId         Int?
  billXExpressStreetId       Int?
  billCompanyName            String?
  billPib                    String?

  notes           String?   @db.Text
  termsAcceptedAt DateTime
  expiresAt       DateTime?
  stockRestoredAt DateTime?
  cancelledAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user                 User?                 @relation(fields: [userId], references: [id])
  customer             Customer?             @relation(fields: [customerId], references: [id], onDelete: SetNull)
  priceList            PriceList?            @relation(fields: [priceListId], references: [id], onDelete: SetNull)
  items                OrderItem[]
  events               OrderStatusEvent[]
  payments             Payment[]
  shipments            Shipment[]
  invoices             Invoice[]
  fiscal               FiscalReceipt?
  fiscalDocuments      FiscalDocument[]
  paymentRefunds       PaymentRefund[]
  stockMovements       StockMovement[]
  reclamations         Reclamation[]
  voucherRedemption    VoucherRedemption?
  checkoutSessions     CheckoutSession[]
  dispatchNotes        DispatchNote[]
  pickupBatchLines     PickupBatchLine[]
  analyticsEvents      AnalyticsEvent[]
  supplierFulfillments SupplierFulfillment[]

  @@index([userId, createdAt])
  @@index([status])
  @@index([expiresAt])
  @@index([createdAt])
  @@index([channel, createdAt])
  @@index([customerId, createdAt])
}

model OrderSequence {
  year      Int      @id
  lastValue Int      @default(0)
  updatedAt DateTime @updatedAt
}

model CheckoutSession {
  id             String                @id
  userId         String?
  guestEmail     String?
  identity       String?
  step           String
  status         CheckoutSessionStatus @default(ACTIVE)
  lineCount      Int                   @default(0)
  itemQty        Int                   @default(0)
