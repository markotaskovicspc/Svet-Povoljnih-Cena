  order Order? @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([status, updatedAt])
  @@index([userId, updatedAt])
  @@index([guestEmail])
  @@index([orderId])
}

model OrderItem {
  id                       String   @id @default(cuid())
  orderId                  String
  productId                String?
  sku                      String
  name                     String
  qty                      Int
  unitPriceFull            Decimal  @db.Decimal(12, 2)
  unitPriceSale            Decimal  @db.Decimal(12, 2)
  withAssembly             Boolean  @default(false)
  assemblyPrice            Decimal? @db.Decimal(12, 2)
  thumbnailUrl             String?
  supplierName             String?
  categoryName             String?
  categoryPath             String?
  groupName                String?
  subgroupName             String?
  collectionName           String?
  shortDescriptionSnapshot String?  @db.Text
  shortNameSnapshot        String?
  attribute1               String?
  attribute2               String?
  attribute3               String?
  attribute4               String?
  color1                   String?
  color2                   String?
  /// Tracks how many times this exact line was reclaimed (for R-{n}-{orderNo})
  reclamationCount         Int      @default(0)
  warehouseId              String?
  warehouseReservedQty     Int      @default(0)
  supplierReservedQty      Int      @default(0)
  supplierExternalSku      String?

  order                   Order                    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product                 Product?                 @relation(fields: [productId], references: [id])
  fiscalLines             FiscalDocumentLine[]
  stockMovements          StockMovement[]
  warehouse               Warehouse?               @relation(fields: [warehouseId], references: [id], onDelete: SetNull)
  pickupBatchLines        PickupBatchLine[]
  dispatchNoteItems       DispatchNoteItem[]
  reclamations            Reclamation[]
  supplierFulfillmentItem SupplierFulfillmentItem?

  @@index([orderId])
  @@index([sku])
  @@index([warehouseId])
}

model OrderStatusEvent {
  id        String      @id @default(cuid())
  orderId   String
  status    OrderStatus
  note      String?     @db.Text
  createdAt DateTime    @default(now())
  /// Optional admin who triggered it
  actorId   String?

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, createdAt])
}

model Payment {
  id               String          @id @default(cuid())
  orderId          String
  method           PaymentMethod
  provider         PaymentProvider @default(MANUAL)
  status           PaymentStatus   @default(PENDING)
  amount           Decimal         @db.Decimal(12, 2)
  currency         String          @default("RSD")
  /// External provider reference (RaiAccept approval, IPS transaction id, etc.)
  providerRef      String?
  paymentReference String?
  redirectUrl      String?         @db.Text
  rawRequest       Json?
  rawResponse      Json?
  paidAt           DateTime?
  expiresAt        DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([providerRef])
  @@index([paymentReference])
  @@index([provider, status])
}

model Shipment {
  id                    String          @id @default(cuid())
  orderId               String
  service               ShipmentService
  provider              String?
  providerOrderId       String?
  providerShipmentId    String?
  trackingNo            String?
  packageCount          Int             @default(1)
  labelUrl              String?
  status                ShipmentStatus  @default(CREATED)
  providerStatusCode    String?
  providerRouteCode     String?
  providerRouteName     String?
  providerParcelId      String?
  providerParcelIds     Json?
  providerParcelNumbers Json?
  lastStatusSyncAt      DateTime?
  rawCreateResponse     Json?
  syncError             String?         @db.Text
  labelObjectKey        String?
  labelMimeType         String?
  shippedAt             DateTime?
  deliveredAt           DateTime?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  order  Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  events ShipmentEvent[]

  @@index([orderId])
  @@index([provider, status, lastStatusSyncAt])
  @@index([providerOrderId])
  @@index([providerShipmentId])
  @@index([trackingNo])
}

model ShipmentEvent {
  id                 String         @id @default(cuid())
  shipmentId         String
  status             ShipmentStatus
  providerStatusCode String?
  providerEventId    String?
  message            String?
  raw                Json?
  occurredAt         DateTime       @default(now())

  shipment Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@unique([providerEventId])
  @@index([shipmentId, occurredAt])
}

model CourierLocationCode {
