  /// Public identifier R-{n}-{orderNo}
  number        String            @unique
  orderId       String
  productId     String?
  sku           String
  customerFirst String
  customerLast  String
  customerEmail String?
  customerPhone String?
  description   String            @db.VarChar(250)
  notifyVia     NotifyChannel
  status        ReclamationStatus @default(PRIMLJENO)
  userId        String?
  createdAt     DateTime          @default(now())
  resolvedAt    DateTime?

  order   Order                    @relation(fields: [orderId], references: [id])
  product Product?                 @relation(fields: [productId], references: [id])
  user    User?                    @relation(fields: [userId], references: [id])
  photos  ReclamationPhoto[]
  events  ReclamationStatusEvent[]

  @@index([orderId])
  @@index([userId])
  @@index([status, resolvedAt])
}

model ReclamationPhoto {
  id            String @id @default(cuid())
  reclamationId String
  url           String
  width         Int?
  height        Int?
  bytes         Int?

  reclamation Reclamation @relation(fields: [reclamationId], references: [id], onDelete: Cascade)

  @@index([reclamationId])
}

model ReclamationStatusEvent {
  id            String            @id @default(cuid())
  reclamationId String
  status        ReclamationStatus
  note          String?           @db.Text
  actorId       String?
  createdAt     DateTime          @default(now())

  reclamation Reclamation @relation(fields: [reclamationId], references: [id], onDelete: Cascade)

  @@index([reclamationId, createdAt])
}

model Comment {
  id        String   @id @default(cuid())
  userId    String?
  name      String
  email     String
  subject   String?
  body      String   @db.Text
  createdAt DateTime @default(now())
  reviewed  Boolean  @default(false)

  user User? @relation(fields: [userId], references: [id])

  @@index([createdAt])
}

model NewsletterSubscriber {
  id             String    @id @default(cuid())
  email          String    @unique
  consent        Boolean   @default(true)
  source         String?
  createdAt      DateTime  @default(now())
  unsubscribedAt DateTime?
}

model ViberAudienceQuery {
  id        String   @id @default(cuid())
  name      String
  /// Filter spec (cities, last-purchase range, etc.)
  filter    Json
  createdAt DateTime @default(now())

  campaigns ViberCampaign[]
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
  FAILED
}

model ViberCampaign {
  id          String         @id @default(cuid())
  audienceId  String
  title       String
  body        String         @db.Text
  imageUrl    String?
  ctaLabel    String?
  ctaUrl      String?
  status      CampaignStatus @default(DRAFT)
  scheduledAt DateTime?
  sentAt      DateTime?
  recipients  Int?
  delivered   Int?
  failed      Int?
  createdAt   DateTime       @default(now())

  audience ViberAudienceQuery @relation(fields: [audienceId], references: [id])

  @@index([status, scheduledAt])
}

// ──────────────────────────────────────────────────────────────────────
// 8. Wishlist & alerts
// ──────────────────────────────────────────────────────────────────────

model WishlistItem {
  id              String   @id @default(cuid())
  userId          String
  productId       String
  notifyOnSale    Boolean  @default(false)
  notifyOnRestock Boolean  @default(false)
  addedAt         DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([productId])
}

model BackInStockAlert {
  id         String        @id @default(cuid())
  userId     String
  productId  String
  channel    NotifyChannel @default(EMAIL)
  createdAt  DateTime      @default(now())
  notifiedAt DateTime?

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId, channel])
  @@index([productId, notifiedAt])
}

model OnSaleAlert {
  id         String        @id @default(cuid())
  userId     String
  productId  String
  channel    NotifyChannel @default(EMAIL)
  createdAt  DateTime      @default(now())
  notifiedAt DateTime?

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId, channel])
  @@index([productId, notifiedAt])
}

// ──────────────────────────────────────────────────────────────────────
// 8. CMS content pages
// ──────────────────────────────────────────────────────────────────────

model ContentPage {
  id             String   @id @default(cuid())
  slug           String   @unique
  title          String
  lead           String?  @db.Text
  bodyMarkdown   String   @db.Text
  seoTitle       String?
  seoDescription String?  @db.Text
  published      Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([published, updatedAt])
}

// ──────────────────────────────────────────────────────────────────────
// 9. Admin
// ──────────────────────────────────────────────────────────────────────

enum AdminRoleName {
  SUPER
  CONTENT
  OPS
  ADS
}

model AdminUser {
  id           String        @id @default(cuid())
  email        String        @unique
  passwordHash String
  firstName    String?
  lastName     String?
  role         AdminRoleName @default(CONTENT)
  enabled      Boolean       @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  auditLogs AuditLog[]
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  action    String
  entity    String
  entityId  String?
  diff      Json?
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  actor AdminUser? @relation(fields: [actorId], references: [id])

  @@index([entity, entityId])
  @@index([createdAt])
}

/// Per-method toggle for the storefront checkout. Seeded with all
/// `PaymentMethod` enum values; admin flips `enabled` to hide a method from
/// the customer payment step without code changes.
model PaymentMethodConfig {
  method    PaymentMethod @id
  enabled   Boolean       @default(true)
  label     String?
  note      String?
  updatedAt DateTime      @updatedAt
}
