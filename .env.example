# badi.rs (FISCAL_PROVIDER=badi); missing credentials fall back to the dev stub
BADI_API_KEY=""
BADI_API_SECRET=""
# sandbox | production (or set BADI_BASE_URL to override)
BADI_ENV="sandbox"
BADI_PRODUCTION_ACCEPTED="false"
BADI_CLIENT_ID=""
# Tax rate label registered with badi products ("Ђ" = 20% standard VAT)
BADI_TAX_RATE_LABEL=""
# Sale invoiceType: normal | training. "training" (obuka) = legally-non-fiscal
# E2E test receipts once a fiscal processor (PFR) is connected; empty ⇒ normal.
BADI_INVOICE_TYPE=""
# VPFR certificate mode — routes receipts through the Tax Authority's cloud
# V-PFR (no always-on LPFR machine). Set all three (bezbednosni element .pfx
# — presumably base64 — its password, and the PAC) or none.
BADI_VPFR_PFX=""
BADI_VPFR_PASSWORD=""
BADI_VPFR_PAC=""
# Supabase bucket for official fiscal PDFs (default "fiscal-receipts")
SUPABASE_FISCAL_BUCKET=""
# Optional dedicated secret for /api/cron/fiscal-retry (falls back to CRON_SECRET)
FISCAL_RETRY_CRON_SECRET=""

