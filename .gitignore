# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# generated media-variant artifacts (variants are uploaded to Supabase, not committed)
/svet akcija/outputs/product-media-variants/
/svet akcija/outputs/svet-akcija-product-media-variants.json
/svet akcija/media-variant-backfill-report.json
/svet akcija/media-variant-url-report.json

# typescript
*.tsbuildinfo
next-env.d.ts
